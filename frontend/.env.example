# Canonical public origin — drives sitemap, robots, canonical URLs, and JSON-LD.
# Required in production (e.g. https://tjt.finance).
NEXT_PUBLIC_SITE_URL=

# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX). Leave empty to disable.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Password for /admin/dashboard (browser session via /api/admin/auth)
ADMIN_PASSWORD="твой_сильный_пароль_здесь"

# Bearer token for POST /api/admin/publish-article (AI agent publishing)
ADMIN_API_SECRET=

# CoinGecko demo/pro API key for live market quotes (/api/market).
# If omitted here, the server also reads ../.env from the project root.
COINGECKO_API_KEY=

# Smart error informer (Telegram alerts) — see src/lib/telegram-logger.ts
# When BOTH are set, critical config.json / sys_registry.json read/write
# failures in the API routes are pushed to a private Telegram chat.
# Leave them empty to disable alerting (the logger silently no-ops).

# BotFather token, e.g. 123456789:AAExxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_BOT_TOKEN=

# Target chat id (your private chat or a channel id, e.g. -1001234567890)
TELEGRAM_CHAT_ID=
