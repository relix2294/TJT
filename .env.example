# Python backend (app.py, ai_agents.py) — copy to .env and fill in values.
OPENAI_API_KEY=

# Shared with Next.js market API (also set in frontend/.env if needed)
COINGECKO_API_KEY=

# Admin dashboard password (also read by frontend/next.config.ts from this file)
ADMIN_PASSWORD=

# Bearer token for POST /api/admin/publish-article (set in frontend/.env too)
ADMIN_API_SECRET=

# Canonical public site URL — used by Next.js SEO and AI publish callbacks.
# Production: https://your-domain.com  |  Local dev: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX). Leave empty to disable.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
